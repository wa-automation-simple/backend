# Environment variables for WhatsApp SaaS

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI Configuration
AI_PROVIDER=openai
AI_API_KEY=your-openai-api-key-here
AI_MODEL=gpt-3.5-turbo

# Token Pricing (Base cost vs Markup price)
TOKEN_BASE_PRICE=3.0
TOKEN_MARKUP_PRICE=10.0

# WhatsApp
WHATSAPP_WEBHOOK_URL=http://localhost:8003/webhook

# Application
APP_NAME=WhatsApp SaaS
DEBUG=true
VERSION=1.0.0
